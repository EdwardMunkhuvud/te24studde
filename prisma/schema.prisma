datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String         @id @default(cuid())
  name         String
  username     String         @unique
  passwordHash String
  role         String         @default("STUDENT")
  targetAmount Int            @default(1050)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  contributions Contribution[]
  announcements Announcement[]
  polls         Poll[]
  pollResponses PollResponse[]
}

model Contribution {
  id          String           @id @default(cuid())
  title       String
  note        String?
  kind        String           @default("MANUAL")
  amount      Int
  periodLabel String?
  occurredAt  DateTime?
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt, sortOrder])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([publishedAt])
}

model Poll {
  id          String         @id @default(cuid())
  title       String
  description String
  type        String
  isOpen      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  authorId    String
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  options     PollOption[]
  responses   PollResponse[]

  @@index([createdAt])
}

model PollOption {
  id        String         @id @default(cuid())
  label     String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  pollId    String
  poll      Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)
  responses PollResponse[]

  @@index([pollId, sortOrder])
}

model PollResponse {
  id             String      @id @default(cuid())
  suggestionText String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  pollId         String
  userId         String
  optionId       String?
  poll           Poll        @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  option         PollOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([pollId, userId])
  @@index([pollId, optionId])
}

model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
